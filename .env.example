# --- إعدادات الأمان الأساسية لـ Django ---
SECRET_KEY=your-super-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,your-app-name.onrender.com

# --- إعدادات تفعيل قاعدة بيانات PostgreSQL (اجعلها True على سيرفر ريندر) ---
USE_POSTGRES=False
DB_NAME=cdms_db
DB_USER=postgres_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# --- إعدادات البريد الإلكتروني الفوري لإشعارات التوجيه ---
EMAIL_HOST_USER=your_college_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_here

# --- إعدادات حفظ النسخ الاحتياطية وتأمينها ---
BACKUP_RETENTION_COUNT=30
